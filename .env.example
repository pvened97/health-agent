# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.4
OPENAI_MODEL_STRONG=gpt-5.4
OPENAI_MODEL_FAST=gpt-5.4-mini

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Database
DATABASE_URL=postgresql+asyncpg://healthagent:healthagent@localhost:5432/healthagent

# Access (comma-separated Telegram user IDs)
ALLOWED_TELEGRAM_USER_IDS=123456789,987654321

# WHOOP OAuth (optional — needed for WHOOP integration)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/whoop/callback

# App
APP_ENV=dev
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

# Webhook (prod only)
TELEGRAM_WEBHOOK_URL=
